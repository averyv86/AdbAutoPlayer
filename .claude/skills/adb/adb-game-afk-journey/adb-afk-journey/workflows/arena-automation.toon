name: AFK Journey Arena Automation
description: Automated arena battles with opponent analysis
version: 1.0.0
metadata:
  game: afk-journey
  workflow_type: arena-automation
  difficulty: advanced
parameters:
  device: 127.0.0.1:5555
  opponent_strategy: strongest
  max_attempts: 5
  claim_rewards: true
phases:
- id: analyze_opponents
  name: Analyze Opponents
  description: Scan opponent formations
  steps:
  - id: analyze_opponents_step1
    name: Analyze Opponents - Step 1
    action: adb-automation
    params:
      device: '{{ device }}'
      timeout: 30
    on_success: continue
    on_failure: continue
  - id: analyze_opponents_step2
    name: Analyze Opponents - Step 2
    action: adb-automation
    params:
      device: '{{ device }}'
      timeout: 30
    on_success: continue
    on_failure: continue
  - id: analyze_opponents_step3
    name: Analyze Opponents - Step 3
    action: adb-automation
    params:
      device: '{{ device }}'
      timeout: 30
    on_success: continue
    on_failure: continue
  - id: analyze_opponents_step4
    name: Analyze Opponents - Step 4
    action: adb-automation
    params:
      device: '{{ device }}'
      timeout: 30
    on_success: continue
    on_failure: abort
- id: select_formation
  name: Select Formation
  description: Choose optimal team formation
  steps:
  - id: select_formation_step1
    name: Select Formation - Step 1
    action: adb-automation
    params:
      device: '{{ device }}'
      timeout: 30
    on_success: continue
    on_failure: continue
  - id: select_formation_step2
    name: Select Formation - Step 2
    action: adb-automation
    params:
      device: '{{ device }}'
      timeout: 30
    on_success: continue
    on_failure: continue
  - id: select_formation_step3
    name: Select Formation - Step 3
    action: adb-automation
    params:
      device: '{{ device }}'
      timeout: 30
    on_success: continue
    on_failure: abort
- id: battle_opponent
  name: Battle Opponent
  description: Execute arena battle
  steps:
  - id: battle_opponent_step1
    name: Battle Opponent - Step 1
    action: adb-automation
    params:
      device: '{{ device }}'
      timeout: 30
    on_success: continue
    on_failure: continue
  - id: battle_opponent_step2
    name: Battle Opponent - Step 2
    action: adb-automation
    params:
      device: '{{ device }}'
      timeout: 30
    on_success: continue
    on_failure: continue
  - id: battle_opponent_step3
    name: Battle Opponent - Step 3
    action: adb-automation
    params:
      device: '{{ device }}'
      timeout: 30
    on_success: continue
    on_failure: continue
  - id: battle_opponent_step4
    name: Battle Opponent - Step 4
    action: adb-automation
    params:
      device: '{{ device }}'
      timeout: 30
    on_success: continue
    on_failure: continue
  - id: battle_opponent_step5
    name: Battle Opponent - Step 5
    action: adb-automation
    params:
      device: '{{ device }}'
      timeout: 30
    on_success: continue
    on_failure: abort
- id: claim_ranking_rewards
  name: Claim Rewards
  description: Get arena rewards
  steps:
  - id: claim_ranking_rewards_step1
    name: Claim Rewards - Step 1
    action: adb-automation
    params:
      device: '{{ device }}'
      timeout: 30
    on_success: continue
    on_failure: continue
  - id: claim_ranking_rewards_step2
    name: Claim Rewards - Step 2
    action: adb-automation
    params:
      device: '{{ device }}'
      timeout: 30
    on_success: continue
    on_failure: abort
validation:
- phase: phase_1
  condition: phase_1_complete == true
  on_failure: continue
- phase: phase_2
  condition: phase_2_complete == true
  on_failure: continue
- phase: phase_3
  condition: phase_3_complete == true
  on_failure: continue
- phase: phase_4
  condition: phase_4_complete == true
  on_failure: abort
recovery:
- on_error: any
  action: retry
  max_attempts: 3
- on_error: timeout
  action: reset_and_retry
  max_attempts: 2
- on_error: device_disconnected
  action: abort
  max_attempts: 1
outputs:
- name: arena-automation_status
  format: json
  description: Workflow execution status
- name: arena-automation_log
  format: text
  description: Detailed execution log
- name: arena-automation_metrics
  format: table
  description: Performance metrics
